---
import '../styles/global.css'
import content from '../data/content.json'

interface Props {
  title?: string
  description?: string
}

const {
  title = content.meta.title,
  description = content.meta.description
} = Astro.props
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={content.meta.og_image} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.kudostoyou.cc/" />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.kudostoyou.cc/" />

    <!-- Font Preloads -->
    <link rel="preload" href="/fonts/rubik-variable-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-sans-variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data: CafeOrCoffeeShop -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CafeOrCoffeeShop",
      "name": "kudos to you",
      "description": content.meta.description,
      "url": "https://www.kudostoyou.cc",
      "telephone": content.brand.phone,
      "email": content.brand.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Colmantstraße 5",
        "addressLocality": "Bonn",
        "postalCode": "53115",
        "addressCountry": "DE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 50.7339,
        "longitude": 7.0986
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "08:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday", "Sunday"],
          "opens": "09:00",
          "closes": "17:00"
        }
      ],
      "servesCuisine": "Coffee, Snacks",
      "priceRange": "€",
      "image": "https://www.kudostoyou.cc/images/aussenansicht.webp",
      "sameAs": [content.brand.social.instagram]
    })} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:rounded-lg focus:bg-white focus:px-4 focus:py-2 focus:text-brand-heading focus:shadow-lg">
      Zum Hauptinhalt springen
    </a>
    <slot />

    <!-- Scroll Reveal Observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible')
              if (entry.target.classList.contains('reveal-stagger')) {
                entry.target.querySelectorAll('.reveal').forEach(child => {
                  child.classList.add('is-visible')
                })
              }
              observer.unobserve(entry.target)
            }
          })
        },
        { threshold: 0.1 }
      )
      document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => observer.observe(el))
    </script>

    <!-- Custom Cursor (desktop + fine pointer only) -->
    <script>
      if (window.matchMedia('(min-width: 1024px) and (pointer: fine)').matches) {
        const dot = document.createElement('div')
        dot.className = 'custom-cursor-dot'
        const ring = document.createElement('div')
        ring.className = 'custom-cursor-ring'
        document.body.appendChild(dot)
        document.body.appendChild(ring)
        document.body.classList.add('has-custom-cursor')

        let mx = 0, my = 0, rx = 0, ry = 0

        document.addEventListener('mousemove', e => {
          mx = e.clientX
          my = e.clientY
          dot.style.left = mx + 'px'
          dot.style.top = my + 'px'
        })

        ;(function follow() {
          rx += (mx - rx) * 0.15
          ry += (my - ry) * 0.15
          ring.style.left = rx + 'px'
          ring.style.top = ry + 'px'
          requestAnimationFrame(follow)
        })()

        const targets = 'a, button, [role="button"], input, textarea, .photo-grain'
        document.querySelectorAll(targets).forEach(el => {
          el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'))
          el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'))
        })

        document.addEventListener('mouseleave', () => {
          dot.style.opacity = '0'
          ring.style.opacity = '0'
        })
        document.addEventListener('mouseenter', () => {
          dot.style.opacity = '1'
          ring.style.opacity = '0.4'
        })
      }
    </script>
  </body>
</html>
