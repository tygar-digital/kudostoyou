---
import content from '../data/content.json'
import { coffeeCup, sparkle, coffeeBean, sketchyHeart } from './Sketches.astro'
import RisingSteam from './RisingSteam.astro'
const { contact, brand } = content
---

<section id="contact" class="relative overflow-hidden bg-brand-bg pb-(--spacing-section) pt-10 lg:pt-14">
  <div class="paper-texture absolute inset-0"></div>

  <!-- Decorative steam cup at top of section -->
  <div class="relative z-10">
    <RisingSteam />
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">
    <!-- Section header — centered -->
    <div class="reveal mx-auto max-w-2xl text-center">
      <div class="mx-auto flex items-center justify-center gap-4">
        <div class="h-[2px] w-8 bg-brand-sage"></div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-sage">
          {contact.sectionLabel}
        </p>
        <div class="h-[2px] w-8 bg-brand-sage"></div>
      </div>
      <h2 class="mt-4 font-heading text-4xl font-bold text-brand-heading sm:text-5xl lg:text-6xl">
        {contact.headline}
      </h2>
      <p class="mt-3 flex items-center justify-center gap-2 font-accent text-xl text-brand-sage">
        Wir freuen uns auf dich.
        <span class="inline-block w-6 opacity-20 rotate-6 [&_path]:!stroke-brand-sage" set:html={sketchyHeart}></span>
      </p>
    </div>

    <!-- Exterior photo — editorial with tilt -->
    <div class="reveal mt-10 overflow-hidden rounded-2xl shadow-xl transition-shadow duration-700 hover:shadow-2xl">
      <div class="photo-grain">
        <img
          src="/images/aussenansicht.webp"
          alt="Außenansicht des kudos to you Cafés in der Colmantstraße in Bonn mit Markise, Fensterfront und Bistro-Stühlen"
          class="w-full object-cover h-48 sm:h-64 lg:h-80"
          loading="lazy"
          width="1200"
          height="1600"
        />
      </div>
    </div>

    <div class="mt-14 grid gap-8 lg:grid-cols-2">
      <!-- Info cards -->
      <div class="reveal-stagger flex flex-col gap-5">
        <!-- Address -->
        <div class="reveal sketch-wobble group rounded-2xl border border-brand-border bg-brand-surface p-7 transition-all duration-500 hover:border-brand-sage/40 hover:shadow-lg hover:shadow-brand-sage/5">
          <div class="absolute inset-x-0 top-0 h-[2px] bg-brand-sage opacity-0 transition-opacity duration-500 group-hover:opacity-100 rounded-t-2xl"></div>
          <div class="flex items-start gap-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-sage-light">
              <svg class="h-5 w-5 text-brand-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-brand-heading">Adresse</h3>
              <p class="mt-1 text-brand-text">{brand.address}</p>
            </div>
          </div>
        </div>

        <!-- Hours -->
        <div class="reveal sketch-wobble group rounded-2xl border border-brand-border bg-brand-surface p-7 transition-all duration-500 hover:border-brand-sage/40 hover:shadow-lg hover:shadow-brand-sage/5">
          <div class="absolute inset-x-0 top-0 h-[2px] bg-brand-sage opacity-0 transition-opacity duration-500 group-hover:opacity-100 rounded-t-2xl"></div>
          <div class="flex items-start gap-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-sage-light">
              <svg class="h-5 w-5 text-brand-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-brand-heading">Öffnungszeiten</h3>
              <div class="mt-2 flex flex-col gap-2">
                {contact.hours.map((h) => (
                  <div class="flex justify-between gap-6 text-sm">
                    <span class="text-brand-text">{h.days}</span>
                    <span class="font-medium text-brand-sage">{h.time}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Contact -->
        <div class="reveal sketch-wobble group rounded-2xl border border-brand-border bg-brand-surface p-7 transition-all duration-500 hover:border-brand-sage/40 hover:shadow-lg hover:shadow-brand-sage/5">
          <div class="absolute inset-x-0 top-0 h-[2px] bg-brand-sage opacity-0 transition-opacity duration-500 group-hover:opacity-100 rounded-t-2xl"></div>
          <div class="flex items-start gap-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-sage-light">
              <svg class="h-5 w-5 text-brand-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-brand-heading">Kontakt</h3>
              <a href={`mailto:${brand.email}`} class="mt-1 block text-brand-sage underline decoration-brand-sage/30 underline-offset-4 transition-colors hover:text-brand-sage-dark hover:decoration-brand-sage-dark">
                {brand.email}
              </a>
              <a href={`tel:${brand.phone.replace(/\s/g, '')}`} aria-label={`Anrufen: ${brand.phone}`} class="mt-0.5 block text-sm text-brand-text underline decoration-brand-border underline-offset-4 transition-colors hover:text-brand-sage hover:decoration-brand-sage">
                {brand.phone}
              </a>
            </div>
          </div>
        </div>

        <!-- Instagram -->
        <a
          href={brand.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="reveal sketch-wobble group flex items-center gap-4 rounded-2xl border border-brand-border bg-brand-surface p-7 transition-all duration-500 hover:border-brand-sage/40 hover:shadow-lg hover:shadow-brand-sage/5"
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-sage text-white">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
          <div>
            <p class="font-heading text-sm font-semibold text-brand-heading">Folge uns auf Instagram</p>
            <p class="text-sm text-brand-muted">@kudostoyou.cc</p>
          </div>
        </a>
      </div>

      <!-- Map: 2-Klick-Lösung (DSGVO) -->
      <div class="reveal flex flex-col overflow-hidden rounded-2xl border border-brand-border">
        <!-- Placeholder -->
        <div id="map-placeholder" class="flex flex-1 min-h-[480px] items-center justify-center bg-brand-surface p-8 text-center">
          <div>
            <svg class="mx-auto h-12 w-12 text-brand-latte" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <h3 class="mt-4 font-heading text-lg font-semibold text-brand-heading">Karte laden</h3>
            <p class="mt-2 text-sm text-brand-muted">
              Mit dem Laden der Karte akzeptierst du die
              <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-brand-sage">Datenschutzerklärung von Google</a>.
            </p>
            <button id="map-consent-btn" aria-label="Google Maps laden – dabei werden Daten an Google übertragen" class="mt-6 inline-flex h-12 items-center rounded-full bg-brand-sage px-8 text-sm font-semibold text-white transition-all hover:bg-brand-sage-dark hover:shadow-lg hover:shadow-brand-sage/20">
              Google Maps laden
            </button>
            <p class="mt-4 text-sm text-brand-muted">{brand.address}</p>
          </div>
        </div>
        <!-- Actual map (hidden until consent) -->
        <iframe
          id="map-iframe"
          class="hidden flex-1 min-h-[480px]"
          data-src={contact.mapEmbed}
          width="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Standort kudos to you"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('map-consent-btn')?.addEventListener('click', () => {
    document.getElementById('map-placeholder')?.classList.add('hidden')
    const iframe = document.getElementById('map-iframe')
    if (iframe) {
      iframe.classList.remove('hidden')
      iframe.setAttribute('src', iframe.getAttribute('data-src') || '')
    }
  })
</script>
