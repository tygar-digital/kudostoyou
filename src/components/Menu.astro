---
import content from '../data/content.json'
import { coffeeCup, coffeeBean, sparkle } from './Sketches.astro'
import LatteArtSVG from './LatteArtSVG.astro'
const { menu } = content
---

<section id="menu" class="relative overflow-hidden bg-brand-espresso pb-(--spacing-section) pt-12 lg:pt-16">
  <div class="grain absolute inset-0 opacity-30"></div>

  <!-- Single subtle sketch accent -->
  <div class="sketch-invert absolute right-[5%] bottom-[8%] w-10 opacity-[0.04] rotate-20" set:html={coffeeBean} />

  <!-- Decorative latte art at top of section -->
  <div class="relative z-10">
    <LatteArtSVG />
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">
    <!-- Section header -->
    <div class="reveal flex items-center gap-4">
      <div class="h-[2px] w-12 bg-brand-sage"></div>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-sage">
        {menu.sectionLabel}
      </p>
    </div>

    <div class="reveal mt-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <h2 class="font-heading text-4xl font-bold text-brand-cream sm:text-5xl lg:text-6xl">
        {menu.headline}
      </h2>
      <div class="flex items-end gap-3">
        <div class="sketch-invert w-10 opacity-30" set:html={coffeeCup} />
        <p class="font-accent text-lg text-brand-latte">Specialty Coffee & mehr</p>
      </div>
    </div>

    <!-- Menu photo — editorial with film grain -->
    <div class="reveal relative mt-10 overflow-hidden rounded-2xl shadow-2xl transition-shadow duration-700 hover:shadow-brand-sage/10">
      <div class="photo-grain">
        <img
          src="/images/croissants-latte.webp"
          alt="Latte Art und frische Croissants auf Holztisch"
          class="mx-auto max-h-[200px] w-full object-cover sm:max-h-[280px] lg:max-h-[380px]"
          loading="lazy"
          width="1200"
          height="1600"
        />
      </div>
    </div>

    <!-- Menu grid -->
    <div class="reveal-stagger mt-14 grid gap-10 md:grid-cols-3">
      {menu.categories.map((category, ci) => (
        <div class="reveal">
          <span class="font-heading text-sm font-bold uppercase tracking-[0.15em] text-brand-sage/60">
                {String(ci + 1).padStart(2, '0')}
              </span>
              <h3 class="mt-1 font-heading text-2xl font-bold text-brand-cream">
                {category.name}
              </h3>
          <!-- Hand-drawn underline -->
          <svg class="mt-3 h-[2px] w-full" viewBox="0 0 300 3" fill="none" preserveAspectRatio="none">
            <path d="M0 1.5 C50 0.5, 100 2.5, 150 1 C200 -0.5, 250 2.5, 300 1.5" stroke="#8FAD74" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
          </svg>

          <ul class="mt-6 flex flex-col gap-5">
            {category.items.map((item) => (
              <li class="group/item">
                <div class="flex items-baseline justify-between gap-3">
                  <span class="font-medium text-brand-cream/90 transition-colors group-hover/item:text-white">
                    {item.name}
                  </span>
                  <span class="flex-1 border-b border-dotted border-brand-latte/20"></span>
                  <span class="shrink-0 font-heading text-sm font-semibold text-brand-sage">
                    {item.price}
                  </span>
                </div>
                {item.description && (
                  <p class="mt-1 text-sm text-brand-latte/60">{item.description}</p>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {menu.note && (
      <p class="reveal mt-12 text-center font-accent text-base text-brand-latte/60">
        {menu.note}
      </p>
    )}
  </div>
</section>
